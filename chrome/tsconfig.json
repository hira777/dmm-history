{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext", // ESM は webpack が変形する
    "jsx": "react-jsx",
    "moduleResolution": "node", // node_modules から モジュールをインポートするために必要
    "baseUrl": "./",
    "paths": {
      "@/*": ["src/*"] // 例: src/utils/history -> @/utils/history
    },
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "types": ["chrome"]
  },
  "include": ["src/**/*"]
}
