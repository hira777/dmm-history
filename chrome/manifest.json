{
  "name": "FANZA History",
  "description": "FANZAの商品閲覧履歴を保存・表示する拡張機能",
  "version": "1.2.2",
  "manifest_version": 3,
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://video.dmm.co.jp/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://video.dmm.co.jp/*"
      ],
      "js": [
        "build/historyWatcher.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://video.dmm.co.jp/*"
      ],
      "js": [
        "build/historySaver.js"
      ],
      "run_at": "document_start"
    }
  ]
}
