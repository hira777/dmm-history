{
  "name": "dmm-history",
  "version": "1.1.1",
  "packageManager": "pnpm@10.21.0",
  "engines": {
    "node": "24.7.0"
  },
  "scripts": {
    "check-types": "tsc -p ./chrome/tsconfig.json --noEmit",
    "dev": "cd chrome && webpack --mode development --watch",
    "build": "cd chrome && webpack --mode production --progress",
    "zip": "zip -r -FS ./dist/chrome.zip chrome -x *src/* -x *webpack.config.js",
    "release": "node release.js && pnpm run build && pnpm run zip",
    "lint": "eslint chrome/src --fix --ext=ts,vue",
    "test": "jest"
  },
  "author": "soarflat",
  "license": "MIT",
  "devDependencies": {
    "@babel/core": "^7.4.4",
    "@babel/preset-env": "^7.4.4",
    "@babel/preset-typescript": "^7.7.4",
    "@types/chrome": "^0.1.42",
    "@types/lodash.orderby": "^4.6.6",
    "@types/node": "^24.7.0",
    "@typescript-eslint/eslint-plugin": "^2.8.0",
    "@typescript-eslint/parser": "^2.8.0",
    "babel-jest": "^24.8.0",
    "css-loader": "^6.0.0",
    "eslint": "^6.7.0",
    "eslint-config-prettier": "^6.7.0",
    "eslint-plugin-jest": "^23.0.4",
    "eslint-plugin-prettier": "^3.1.1",
    "eslint-plugin-vue": "^6.0.1",
    "jest": "^24.8.0",
    "pug": "^2.0.0-rc.3",
    "pug-loader": "^2.3.0",
    "pug-plain-loader": "^1.0.0",
    "sass": "^1.100.0",
    "sass-loader": "^13.0.0",
    "style-loader": "^0.19.0",
    "terser-webpack-plugin": "^5.6.0",
    "ts-loader": "^9.0.0",
    "typescript": "^4.9.5",
    "vue-loader": "^15.0.0",
    "vue-property-decorator": "^8.3.0",
    "vue-style-loader": "^4.1.3",
    "vue-template-compiler": "^2.5.16",
    "vuex-module-decorators": "^0.11.0",
    "webpack": "^5.107.1",
    "webpack-cli": "^7.0.2"
  },
  "dependencies": {
    "@types/jest": "^24.0.23",
    "bulma": "^0.7.0",
    "date-fns": "^1.29.0",
    "lodash.orderby": "^4.6.0",
    "vue": "^2.5.16",
    "vuex": "^3.0.1"
  }
}
