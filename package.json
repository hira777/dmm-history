{
  "name": "dmm-history",
  "version": "1.1.1",
  "packageManager": "pnpm@10.21.0",
  "engines": {
    "node": "24.7.0"
  },
  "scripts": {
    "check-types": "tsc -p ./chrome/tsconfig.json --noEmit",
    "dev": "cd chrome && webpack --mode development --watch",
    "dev:history": "cd chrome && webpack serve --mode development --env historyDevServer=true",
    "build": "cd chrome && webpack --mode production --progress",
    "zip": "zip -r -FS ./dist/chrome.zip chrome -x *src/* -x *webpack.config.js",
    "release": "node release.js && pnpm run build && pnpm run zip",
    "lint": "eslint chrome/src --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "author": "soarflat",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/chrome": "^0.1.42",
    "@types/lodash.orderby": "^4.6.6",
    "@types/node": "^24.7.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "css-loader": "^6.0.0",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "sass": "^1.100.0",
    "sass-loader": "^17.0.0",
    "style-loader": "^3.0.0",
    "terser-webpack-plugin": "^5.6.0",
    "ts-loader": "^9.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.1.7",
    "webpack": "^5.107.1",
    "webpack-cli": "^7.0.2",
    "webpack-dev-server": "^5.2.4"
  },
  "dependencies": {
    "date-fns": "^1.29.0",
    "lodash.orderby": "^4.6.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
